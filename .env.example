# ============================================================================
# GameGuard 环境变量模板
# ----------------------------------------------------------------------------
# 使用方法：
#   cp .env.example .env
#   然后按下方注释填入你实际使用的 provider 的 key。
#   .env 已在 .gitignore 中，不会被提交。
# ============================================================================

# ----- LLM 路由（核心）------------------------------------------------------
# GameGuard 的 LLM 网关层是 LiteLLM，所有 provider 通过 `provider/model` 字符串
# 统一访问。下面的 MODEL 名字直接传给 LiteLLM 的 completion()。
#
# 常用示例：
#   zai/glm-5.1                  智谱 GLM-5.1（推理型，Stage 3 实测 DesignDoc recall 最高）
#   zai/glm-4.7                  智谱 GLM-4.7（推理型，需配合 GAMEGUARD_DISABLE_THINKING=1）
#   zai/glm-4.6                  智谱 GLM-4.6（非推理型，智谱当家；注意 LiteLLM 多轮协议偶有错乱）
#   zai/glm-4.5                  智谱 GLM-4.5（最便宜）
#   openai/gpt-4.1               OpenAI 2025 tool-use 优化款（function-calling 原产地，需 OPENAI_API_KEY）
#   anthropic/claude-sonnet-4-6  Anthropic（需 ANTHROPIC_API_KEY）
#   deepseek/deepseek-chat       DeepSeek（非推理型；当前 baseline，需 DEEPSEEK_API_KEY）
GAMEGUARD_MODEL=zai/glm-4.7

# 辅助（triage 聚类/去重）可选择用更便宜的模型省钱
GAMEGUARD_MODEL_TRIAGE=zai/glm-4.6

# ----- Provider API keys ----------------------------------------------------
# 只需要填你实际在用的那一家。LiteLLM 会按上面 GAMEGUARD_MODEL 的
# `provider/model` 前缀自动挑 key。
#
# 主管线（gameguard run / generate / regress）只用到 GAMEGUARD_MODEL 对应
# 的那一把；evals/compare_models 会按参数（--models deepseek,glm-5.1,...）
# 多家同时要钥匙——跑对比实验前按需把对应 key 填上即可，不跑就留空。
ZAI_API_KEY=            # zai/* 模型（GLM-4.5 / 4.6 / 4.7 / 5.1）
ZHIPU_API_KEY=          # 备用：智谱官方 key 名（部分场景下 LiteLLM 回退用）
DEEPSEEK_API_KEY=       # deepseek/* 模型（当前 baseline provider）
OPENAI_API_KEY=         # openai/* 模型；evals/compare_models 的 gpt-4.1 需要
ANTHROPIC_API_KEY=      # anthropic/* 模型（暂未进对比池，留作未来扩展）

# ----- 成本与确定性护栏 ------------------------------------------------------
# 单次 `gameguard run` / `gameguard regress` 的美元预算上限。超过立即抛错。
# LiteLLM 会按 provider 的实际定价估算；没定价的 provider 退化为按 token 估。
GAMEGUARD_USD_BUDGET=0.50

# 强制开启"确定性模式"：
#   - temperature = 0
#   - 必须命中磁盘缓存，否则抛错（避免 CI 跑时意外消耗额度）
# CI 场景建议开启；本地探索时关闭。
GAMEGUARD_DETERMINISTIC=0

# LLM 磁盘缓存根目录（相对于项目根）。删掉即可强制重跑。
GAMEGUARD_CACHE_DIR=.cache/llm

# ----- Token 预算（次级保险）------------------------------------------------
# 即便美元预算没超，token 累计也不应超过这个数；防止出现 loop 刷爆 context。
GAMEGUARD_TOKEN_BUDGET=500000

# ----- 调试 -----------------------------------------------------------------
# 1: 打印所有 LLM 请求/响应到 stderr；0: 静默
GAMEGUARD_DEBUG_LLM=0

# ----- 推理模型治理 ----------------------------------------------------------
# 关闭 GLM-4.7/5/5.1、Claude thinking、o1/o3 等推理型模型的 "thinking" 输出。
# tool-calling 场景下强烈建议设 1：避免 max_tokens 全部消耗在 reasoning_content
# 上、tool_calls 输出空的"静默推理"失败模式。0 = 保留 thinking。
GAMEGUARD_DISABLE_THINKING=1
