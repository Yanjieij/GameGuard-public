        </mxCell>
        <mxCell id="subtitle" value="让昂贵 / 有随机性的 Plan 阶段尽量短，让 CI / 回归走纯确定性路径" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="240" y="46" width="1000" height="22" as="geometry" />
