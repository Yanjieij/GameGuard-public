        </mxCell>
        <mxCell id="exec_lane_title" value="② Execute 阶段 · 纯确定性 · seed 决定结果 · CI 可重复" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#b46504;" vertex="1" parent="1">
          <mxGeometry x="760" y="100" width="700" height="28" as="geometry" />
        </mxCell>

        <mxCell id="doc_in" value="策划文档&#10;docs/example_skill_v1.md&#10;docs/example_quest_harbor.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="230" y="150" width="320" height="70" as="geometry" />
        </mxCell>

        <mxCell id="design_agent" value="DesignDocAgent&#10;&#10;工具: list_docs · list_doc_sections&#10;       read_doc_section · emit_invariant&#10;&#10;LLM: 浏览目录 → 读关键节 → 抽机器可验证不变式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="130" y="260" width="520" height="110" as="geometry" />
        </mxCell>

        <mxCell id="invariant_out" value="InvariantBundle&#10;19 种 kind · Pydantic discriminated union" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff4e5;strokeColor=#d79b00;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="210" y="400" width="360" height="80" as="geometry" />
        </mxCell>

        <mxCell id="testgen_agent" value="TestGenAgent&#10;&#10;工具: list_invariants · list_skills · list_quests&#10;       list_entities · emit_testcase · finalize&#10;&#10;双模式: discovery (LLM 主动浏览) / prefetch (省钱)&#10;策略: Contract / Property / Exploratory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="100" y="510" width="580" height="130" as="geometry" />
        </mxCell>

        <mxCell id="critic_agent" value="CriticAgent (stretch · review_hook)&#10;&#10;工具: inspect_case · propose_fix · drop_case · accept_all&#10;&#10;对每条生成用例：静态校验 → LLM 决策 accept / patch / drop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="680" width="580" height="110" as="geometry" />
        </mxCell>

        <mxCell id="plan_out" value="TestPlan.yaml&#10;进 git · 可像 code 一样 review&#10;seed · actions · assertions" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff4e5;strokeColor=#d79b00;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="210" y="830" width="360" height="90" as="geometry" />
        </mxCell>

        <mxCell id="runner" value="Runner + Sandbox&#10;&#10;for case in plan:&#10;  reset(seed)&#10;  for action in actions: step(action)&#10;  for inv in assertions: evaluate(inv, view, log)&#10;&#10;落盘: EventLog (JSONL) · Snapshot · suite.json&#10;Sandbox: pysim v1/v2 · questsim v1/v2 · unity:mock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="820" y="260" width="580" height="160" as="geometry" />
        </mxCell>

        <mxCell id="suite_result" value="TestSuiteResult&#10;PASSED / FAILED / ERROR 三态 · trace + snapshot 路径" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff4e5;strokeColor=#d79b00;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="900" y="450" width="420" height="80" as="geometry" />
        </mxCell>

        <mxCell id="branch_q" value="有 FAILED / ERROR 吗？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="980" y="560" width="260" height="70" as="geometry" />
        </mxCell>

        <mxCell id="triage_agent" value="TriageAgent&#10;&#10;Stage 1 规则聚类 (kind + invariant_id + actor)&#10;Stage 2 LLM-as-judge (size&gt;1 的簇)&#10;&#10;工具: list_failures · emit_bug_report · merge_clusters" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="820" y="670" width="580" height="120" as="geometry" />
        </mxCell>

        <mxCell id="bugreport" value="BugReport (Jira-compatible)&#10;bug_id · severity · component · repro_steps · invariant_violated" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="820" y="830" width="580" height="80" as="geometry" />
        </mxCell>

        <mxCell id="regress_box" value="regress 模式: 同 plan 跑两次 (baseline/candidate) → RegressDiff (NEW / FIXED / FLAKY / STABLE) → Jinja2 HTML 报告" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=2;align=center;verticalAlign=middle;" vertex="1" parent="1">
